rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidExpensePayload(data) {
      return data.keys().hasAll([
        'userId',
        'categoryId',
        'categoryNameSnapshot',
        'categoryIconSnapshot',
        'categoryColorSnapshot',
        'description',
        'date',
        'createdAt',
        'updatedAt',
        'amountUah',
        'originalAmount',
        'originalCurrency',
        'rateUahPerOriginal'
      ])
      && data.userId is string
      && data.categoryId is string
      && data.categoryId.size() > 0
      && data.categoryNameSnapshot is string
      && data.categoryNameSnapshot.size() > 0
      && data.categoryIconSnapshot is string
      && data.categoryIconSnapshot.size() > 0
      && data.categoryColorSnapshot is int
      && data.description is string
      && data.date is timestamp
      && data.createdAt is timestamp
      && data.updatedAt is timestamp
      && data.amountUah is number
      && data.amountUah > 0
      && data.originalAmount is number
      && data.originalAmount > 0
      && data.originalCurrency is string
      && data.originalCurrency.size() >= 3
      && data.rateUahPerOriginal is number
      && data.rateUahPerOriginal > 0;
    }

    function isValidCategoryPayload(data) {
      return data.keys().hasAll([
        'userId',
        'name',
        'icon',
        'colorValue',
        'monthlyBudget',
        'isArchived',
        'createdAt',
        'updatedAt'
      ])
      && data.userId is string
      && data.name is string
      && data.name.size() > 0
      && data.icon is string
      && data.icon.size() > 0
      && data.colorValue is int
      && data.monthlyBudget is number
      && data.monthlyBudget >= 0
      && data.isArchived is bool
      && data.createdAt is timestamp
      && data.updatedAt is timestamp;
    }

    match /expenses/{expenseId} {
      allow read: if isOwner(resource.data.userId);

      allow create: if isOwner(request.resource.data.userId)
                    && isValidExpensePayload(request.resource.data);

      allow update: if isOwner(resource.data.userId)
                    && isOwner(request.resource.data.userId)
                    && request.resource.data.userId == resource.data.userId
                    && isValidExpensePayload(request.resource.data);

      allow delete: if isOwner(resource.data.userId);
    }

    match /categories/{categoryId} {
      allow read: if isOwner(resource.data.userId);

      allow create: if isOwner(request.resource.data.userId)
                    && isValidCategoryPayload(request.resource.data);

      allow update: if isOwner(resource.data.userId)
                    && isOwner(request.resource.data.userId)
                    && request.resource.data.userId == resource.data.userId
                    && isValidCategoryPayload(request.resource.data);

      allow delete: if isOwner(resource.data.userId);
    }

    match /userSettings/{userId} {
      allow read: if isOwner(userId);

      allow create: if isOwner(userId) &&
                     request.resource.data.userId == userId;

      allow update: if isOwner(userId) &&
                     request.resource.data.userId == userId;

      allow delete: if isOwner(userId);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
